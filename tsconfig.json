{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/tests/**/*.ts",
    "**/solution/**/*.ts"
  ]
}
